#!/usr/bin/env bash
set -euo pipefail

SOURCE="${SOURCE:-$(pactl list sources short 2>/dev/null | { grep -i 'alsa_input.*Sound_Blaster_X3' || true; } | head -1 | awk '{print $2}')}"
if [[ -z "$SOURCE" ]]; then
    echo "Error: Sound Blaster X3 input source not found. Set SOURCE= env var." >&2
    exit 1
fi
SINK="unified-upmix"
LINEIN_PORT="${LINEIN_PORT:-analog-input}"
MIC_PORT="${MIC_PORT:-analog-input-mic}"
STATE_FILE="/tmp/vinyl-loopback-module"

is_active() {
    [[ -f "$STATE_FILE" ]]
}

link() {
    pactl set-source-port "$SOURCE" "$LINEIN_PORT" 2>/dev/null || true
    MODULE_ID=$(pactl load-module module-loopback \
        source="$SOURCE" \
        sink="$SINK" \
        latency_msec=20 \
        source_dont_move=true \
        sink_dont_move=true)
    echo "$MODULE_ID" > "$STATE_FILE"
    echo "Vinyl passthrough ON (line-in → unified-upmix, module $MODULE_ID)"
}

unlink() {
    if [[ -f "$STATE_FILE" ]]; then
        MODULE_ID=$(cat "$STATE_FILE")
        pactl unload-module "$MODULE_ID" 2>/dev/null || true
        rm -f "$STATE_FILE"
    fi
    echo "Vinyl passthrough OFF"
    pactl set-source-port "$SOURCE" "$MIC_PORT" 2>/dev/null || true
}

case "${1:-}" in
    on)  is_active && echo "Already ON" || link ;;
    off) is_active && unlink || echo "Already OFF" ;;
    status) is_active && echo "ON" || echo "OFF" ;;
    *)
        if is_active; then
            unlink
        else
            link
        fi
        ;;
esac